# Copia este archivo como terraform.tfvars y completa con tus valores reales.
# NUNCA subas terraform.tfvars a git (está en .gitignore).

# ──────────────────────────────────────────────────────────────────────────────
# REQUERIDO
# ──────────────────────────────────────────────────────────────────────────────

# Token de DigitalOcean → https://cloud.digitalocean.com/account/api/tokens
do_token = "dop_v1_REEMPLAZA_CON_TU_TOKEN"

# Repositorios GitHub (el repo debe estar conectado a DigitalOcean Apps)
# Formato: "nombre-usuario-o-org/nombre-repositorio"
backend_github_repo  = "tu-org/exitojuntos-server"
frontend_github_repo = "tu-org/exitojuntos"

# JWT
jwt_secret = "cambia-esto-por-un-secret-seguro-de-al-menos-32-chars"

# Brevo (emails)
brevo_api_key = "xkeysib-REEMPLAZA_CON_TU_API_KEY"

# ──────────────────────────────────────────────────────────────────────────────
# OPCIONAL (dejar vacío si no usas S3)
# ──────────────────────────────────────────────────────────────────────────────

aws_access_key_id     = ""
aws_secret_access_key = ""
aws_region            = ""
aws_bucket_name       = ""

# ──────────────────────────────────────────────────────────────────────────────
# CONFIGURACIÓN (valores por defecto razonables para un proyecto pequeño)
# ──────────────────────────────────────────────────────────────────────────────

app_name              = "exitojuntos"
region                = "nyc"           # nyc, fra, ams, sgp, syd, lon, tor, blr, sfo
backend_instance_size = "apps-s-1vcpu-0.5gb"  # ~$5/mes
db_size               = "db-s-1vcpu-1gb"      # ~$15/mes PG + ~$15/mes Redis
jwt_expires_in        = "1d"
